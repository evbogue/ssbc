{
  "name": "ssbc",
  "description": "Secure-Scuttlebot Classic: a modernized SSB server with the Decent web UI and git-over-SSB",
  "version": "16.0.1",
  "homepage": "https://github.com/evbogue/ssbc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evbogue/ssbc.git"
  },
  "bin": {
    "sbot": "./bin.js",
    "ssb-server": "./bin.js"
  },
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "start": "node bin.js start",
    "build:web": "node decent/scripts/style.js && mkdir -p decent/build && browserify decent/src/main.js | indexhtmlify --title \"Decent SSB\" > decent/build/index.html && node decent/scripts/postprocess-index.js",
    "sync:scuttlebot-docs": "bash scripts/sync-scuttlebot-docs.sh",
    "gen:api-reference": "node scripts/gen-api-reference.js",
    "prepublishOnly": "npm test",
    "test": "set -e; for t in test/*.js; do echo TEST $t; node $t; done",
    "test:pretty": "npm run test | tap-spec",
    "lint": "eslint lib plugins bin.js index.js",
    "reinstall": "rm -rf node_modules package-lock.json npm-shrinkwrap.json; export npm_config_package_lock=true; npm install && npm dedupe && npm shrinkwrap",
    "coverage": "nyc --reporter=lcov npm test"
  },
  "dependencies": {
    "cont": "^1.0.3",
    "dataurl-": "^0.1.0",
    "debug": "^4.1.1",
    "depject": "^3.0.0",
    "emoji-named-characters": "^1.0.2",
    "git-ssb": "^2.3.6",
    "hjson": "^2.0.3",
    "human-time": "0.0.1",
    "hypercombo": "0.1.0",
    "hypercrop": "^1.0.1",
    "hyperfile": "^1.1.0",
    "hyperlightbox": "^0.1.3",
    "hyperprogress": "0.1.0",
    "hyperscript": "^1.4.7",
    "is-visible": "^2.0.4",
    "kvgraph": "^0.1.0",
    "layered-graph": "^1.2.0",
    "map-filter-reduce": "^3.0.1",
    "markdown-it": "^14.2.0",
    "mdmanifest": "^1.0.8",
    "multiblob": "^1.13.0",
    "multiserver": "^3.3.1",
    "multiserver-address": "^1.0.1",
    "muxrpcli": "3",
    "prismjs": "^1.30.0",
    "pull-cat": "~1.1.5",
    "pull-next": "^0.0.1",
    "pull-pause": "0.0.0",
    "pull-pushable": "^2.2.0",
    "pull-reconnect": "^0.0.3",
    "pull-stream": "^3.6.2",
    "secret-stack": "^6.3.1",
    "simple-mime": "^0.1.0",
    "split-buffer": "^1.0.0",
    "ssb-avatar": "^0.2.0",
    "ssb-blobs": "1.2.2",
    "ssb-client": "^4.7.9",
    "ssb-config": "^3.2.5",
    "ssb-ebt": "^5.6.1",
    "ssb-git": "^0.5.0",
    "ssb-git-repo": "^2.8.3",
    "ssb-gossip": "^1.1.0",
    "ssb-keys": "^7.1.1",
    "ssb-links": "^3.0.10",
    "ssb-markdown": "^3.0.0",
    "ssb-mentions": "^0.1.0",
    "ssb-plugins": "^1.0.4",
    "ssb-private1": "^1.0.1",
    "ssb-query": "^2.4.0",
    "ssb-ref": "^2.13.9",
    "ssb-sort": "^1.0.0",
    "ssb-validate": "^4",
    "ssb-ws": "^6.2.1",
    "suggest-box": "^2.2.1",
    "text-node-searcher": "^1.1.0",
    "visualize-buffer": "0.0.0"
  },
  "devDependencies": {
    "browserify": "^16.5.2",
    "eslint": "^8.57.0",
    "indexhtmlify": "^1.3.1",
    "nyc": "^15.1.0",
    "pull-abortable": "^4.1.1",
    "pull-paramap": "^1.2.2",
    "run-series": "^1.1.8",
    "semver": "^7.6.0",
    "tap-spec": "^5.0.0",
    "tape": "^5.0.0"
  },
  "nyc": {
    "exclude": [
      "!**/node_modules/",
      "**/node_modules/**/{test,node_modules}/"
    ],
    "include": [
      "*.js",
      "lib/*.js",
      "plugins/*.js",
      "node_modules/{ssb-*,flume*,secret-stack,muxrpc,multiserver}/*.js",
      "node_modules/{ssb-*,flume*,secret-stack,muxrpc,multiserver}/{util,lib,frame,indexes}/*.js"
    ]
  },
  "author": "Paul Frazee <pfrazee@gmail.com>",
  "license": "MIT"
}
